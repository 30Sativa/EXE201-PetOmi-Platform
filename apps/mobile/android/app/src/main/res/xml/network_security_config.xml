<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      MAC DINH: chan toan bo HTTP khong ma hoa (cleartext) -> production an toan,
      Google Play khong canh bao. Moi ket noi phai la HTTPS.
    -->
    <base-config cleartextTrafficPermitted="false" />

    <!--
      NGOAI LE: chi cho phep HTTP voi cac dia chi DEV/LOCAL de test API local.
      - 10.0.2.2  : la localhost cua may tinh khi chay tren Android Emulator
      - localhost / 127.0.0.1 : chay tren may that qua adb reverse
      NEU production khong dung HTTP local thi co the xoa block <domain-config> nay.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
